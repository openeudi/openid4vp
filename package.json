{
  "name": "@openeudi/openid4vp",
  "version": "0.4.0",
  "description": "OpenID4VP credential parsing and validation for EUDI Wallets (SD-JWT VC + mDOC)",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@openeudi/dcql": "^0.1.1",
    "@peculiar/x509": "^2.0.0",
    "@sd-jwt/decode": "^0.19.0",
    "cbor-x": "^1.6.0",
    "jose": "^6.1.3",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@peculiar/asn1-cms": "^2.6.1",
    "@peculiar/asn1-ocsp": "^2.6.1",
    "@peculiar/asn1-schema": "^2.6.0",
    "@peculiar/asn1-x509": "^2.6.1",
    "@peculiar/webcrypto": "^1.5.0",
    "@vitest/coverage-v8": "^4.1.5",
    "reflect-metadata": "^0.2.2",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/openeudi/openid4vp"
  },
  "keywords": [
    "openid4vp",
    "eudi",
    "sd-jwt",
    "mdoc",
    "verifiable-credentials",
    "eidas"
  ]
}
