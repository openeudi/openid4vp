{
  "name": "@openeudi/openid4vp",
  "version": "0.1.0",
  "description": "OpenID4VP credential parsing and validation for EUDI Wallets (SD-JWT VC + mDOC)",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@sphereon/pex": "5.0.0-unstable.28",
    "@sphereon/ssi-types": "^0.37.1",
    "@sd-jwt/decode": "^0.19.0",
    "cbor-x": "^1.6.0",
    "cose-js": "^0.9.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "tsup": "^8.5.1",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "openid4vp",
    "eudi",
    "sd-jwt",
    "mdoc",
    "verifiable-credentials",
    "eidas"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/openeudi/openid4vp"
  },
  "homepage": "https://github.com/openeudi/openid4vp#readme",
  "bugs": {
    "url": "https://github.com/openeudi/openid4vp/issues"
  },
  "author": "OpenEUDI Contributors"
}
